# ===========================================
# Agentic Paper Trading System - Environment
# ===========================================

# -----------------------------------------
# LLM Provider - Groq (FREE tier available)
# Get API key: https://console.groq.com/keys
# -----------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------
# Broker API - DhanHQ (Sandbox for paper trading)
# 1. Create account: https://dhan.co
# 2. Developer Portal: https://developer.dhan.co
# 3. Sandbox Token: https://developer.dhan.co (use sandbox URL below)
# 4. Production Token: https://web.dhan.co (use api.dhan.co URL)
# -----------------------------------------
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
# Use sandbox.dhan.co for sandbox tokens, api.dhan.co for production
DHAN_BASE_URL=https://sandbox.dhan.co/v2
# -----------------------------------------
# Observability - LangSmith (FREE tier: 5K traces/month)
# Get API key: https://smith.langchain.com/settings
# -----------------------------------------
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=trading-agent
LANGSMITH_TRACING_V2=true

# -----------------------------------------
# Database - PostgreSQL (FREE cloud options)
# 
# Option 1: Neon (RECOMMENDED - 0.5GB free)
#   https://neon.tech → Create project → Copy connection string
#
# Option 2: Supabase (500MB free)
#   https://supabase.com → New project → Settings > Database > Connection string
#
# Option 3: Railway (500MB free trial)
#   https://railway.app → New project → Add PostgreSQL
# -----------------------------------------
DATABASE_URL=postgresql://user:password@your-db-host.neon.tech/trading_agent?sslmode=require

# Trading Configuration
TRADING_MODE=paper  # paper | live
MAX_DAILY_TRADES=50
MAX_POSITION_SIZE=100000
DAILY_LOSS_LIMIT=10000

# ===========================================
# Free Tier Configuration (NEW)
# ===========================================
# Market data source: yfinance (free) or dhan (requires account)
MARKET_DATA_SOURCE=yfinance

# Execution mode: local_paper (free), dhan_paper (sandbox), or live
EXECUTION_MODE=local_paper

# Enable AI-powered news sentiment analysis
ENABLE_NEWS_ANALYSIS=true

# Starting balance for local paper trading (INR)
PAPER_WALLET_BALANCE=1000000

# ===========================================
# Telegram Notifications (Optional)
# ===========================================
# Get bot token: Talk to @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get chat ID: Talk to @userinfobot on Telegram
# TELEGRAM_CHAT_ID=your_chat_id_here

# Enable/disable Telegram notifications
TELEGRAM_ENABLED=true
